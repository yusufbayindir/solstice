        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Φτιαγμένο με φροντίδα. Χωρίς παρακολούθηση, χωρίς cloud."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Hecho con cuidado. Sin seguimiento, sin nube."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tehty huolella. Ei seurantaa, ei pilveä."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Conçu avec soin. Aucun suivi, aucun cloud."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "נוצר בקפידה. בלי מעקב, בלי ענן."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "ध्यान से बनाया गया। कोई ट्रैकिंग नहीं, कोई क्लाउड नहीं।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Gondossággal készült. Nincs követés, nincs felhő."
