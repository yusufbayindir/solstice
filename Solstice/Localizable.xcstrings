    "Estimate improves as you log more.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Estimate improves as you log more."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "يتحسّن التقدير كلما سجّلتِ المزيد."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Odhad se zpřesňuje, jak zaznamenáváte více."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Skønnet bliver bedre, jo mere du registrerer."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Schätzung wird genauer, je mehr du erfasst."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Η εκτίμηση βελτιώνεται όσο καταγράφετε περισσότερα."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La estimación mejora a medida que registras más."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Arvio tarkentuu, kun kirjaat enemmän."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'estimation s'améliore au fur et à mesure de vos saisies."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "ההערכה משתפרת ככל שתתעדי יותר."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "जैसे-जैसे आप अधिक दर्ज करते हैं, अनुमान बेहतर होता जाता है।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A becslés pontosabb lesz, ahogy többet rögzítesz."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Perkiraan akan makin akurat seiring Anda mencatat lebih banyak."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La stima migliora man mano che registri più dati."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "記録を重ねるほど、予測の精度が上がります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기록이 쌓일수록 예측이 정확해집니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Anggaran menjadi lebih tepat apabila anda merekod lebih banyak."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Anslaget blir bedre jo mer du logger."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "De schatting wordt nauwkeuriger naarmate je meer logt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Prognoza staje się dokładniejsza, im więcej zapisujesz."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "A estimativa melhora conforme você registra mais."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "A estimativa melhora à medida que regista mais."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Estimarea devine mai precisă pe măsură ce notezi mai mult."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Прогноз становится точнее по мере того, как вы вносите больше записей."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Uppskattningen blir bättre ju mer du loggar."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "การคาดการณ์จะแม่นยำขึ้นเมื่อคุณบันทึกมากขึ้น"
          }
        },
        "tr": {
