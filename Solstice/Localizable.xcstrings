    "Your logs and history won't be changed — only your cycle length and period preferences will be reset.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your logs and history won't be changed — only your cycle length and period preferences will be reset."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لن تتغير سجلاتك ولا تاريخك، إذ ستُعاد فقط ضبط مدة دورتك وتفضيلات الدورة الشهرية."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vaše záznamy a historie se nezmění — obnoví se pouze délka cyklu a předvolby menstruace."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Dine registreringer og din historik ændres ikke — kun din cykluslængde og dine menstruationsindstillinger nulstilles."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Deine Aufzeichnungen und dein Verlauf werden nicht geändert — nur deine Zykluslänge und Periodeneinstellungen werden zurückgesetzt."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Οι καταγραφές και το ιστορικό σας δεν θα αλλάξουν — θα επαναφερθούν μόνο η διάρκεια κύκλου και οι προτιμήσεις περιόδου σας."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tus registros e historial no cambiarán — solo se restablecerán la duración de tu ciclo y tus preferencias de periodo."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Merkintöjäsi ja historiaasi ei muuteta — vain kierron pituus ja kuukautisasetukset nollataan."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vos enregistrements et votre historique ne seront pas modifiés — seules la durée de votre cycle et vos préférences de règles seront réinitialisées."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "התיעודים וההיסטוריה שלך לא ישתנו — רק העדפות אורך המחזור והווסת יאופסו."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपके लॉग और इतिहास नहीं बदलेंगे — केवल आपकी चक्र लंबाई और पीरियड प्राथमिकताएँ रीसेट होंगी।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A bejegyzéseid és előzményeid nem változnak — csak a ciklushossz és a menstruációs beállítások állnak vissza."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Catatan dan riwayat Anda tidak akan berubah — hanya panjang siklus dan preferensi haid Anda yang akan diatur ulang."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le tue registrazioni e la cronologia non verranno modificate — verranno reimpostate solo la durata del ciclo e le preferenze delle mestruazioni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "記録や履歴は変更されません。周期の長さと生理の設定だけがリセットされます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기록과 이력은 변경되지 않으며, 주기 길이와 생리 설정만 초기화됩니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Rekod dan sejarah anda tidak akan diubah — hanya tempoh kitaran dan keutamaan haid anda yang akan ditetapkan semula."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Loggene og historikken din endres ikke — bare sykluslengden og mensinnstillingene dine tilbakestilles."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je gelogde gegevens en geschiedenis blijven ongewijzigd — alleen je cycluslengte en menstruatievoorkeuren worden opnieuw ingesteld."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Twoje zapisy i historia pozostaną bez zmian — zresetowane zostaną jedynie długość cyklu i ustawienia miesiączki."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Seus registros e histórico não serão alterados — apenas a duração do ciclo e as preferências da menstruação serão redefinidas."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Os seus registos e histórico não serão alterados — apenas a duração do ciclo e as preferências da menstruação serão repostas."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Înregistrările și istoricul tău nu vor fi modificate — vor fi resetate doar durata ciclului și preferințele privind menstruația."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваши записи и история останутся без изменений — сбросятся только длина цикла и параметры месячных."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Dina loggar och din historik ändras inte — endast din cykellängd och dina mensinställningar återställs."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "บันทึกและประวัติของคุณจะไม่เปลี่ยน — รีเซ็ตเฉพาะความยาวรอบเดือนและการตั้งค่าประจำเดือนเท่านั้น"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kayıtlarınız ve geçmişiniz değişmez — yalnızca döngü uzunluğunuz ve adet tercihleriniz sıfırlanır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваші записи й історія залишаться без змін — буде скинуто лише тривалість циклу та параметри менструації."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Nhật ký và lịch sử của bạn sẽ không thay đổi — chỉ độ dài chu kỳ và tùy chọn kỳ kinh được đặt lại."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的记录和历史不会被改动，仅会重置周期长度和经期偏好。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的記錄與歷史不會變動，僅會重設週期長度與經期偏好。"
          }
        }
      }
    },
