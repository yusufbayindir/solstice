            "value": "لقد فعّلتِ قفل التطبيق للتو. صادقي على هويتك للمتابعة."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Právě jste zapnuli Zámek aplikace. Pokračujte ověřením totožnosti."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Du har lige aktiveret app-lås. Godkend dig selv for at fortsætte."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du hast gerade die App-Sperre aktiviert. Authentifiziere dich, um fortzufahren."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Μόλις ενεργοποιήσατε το Κλείδωμα Εφαρμογής. Επαληθεύστε την ταυτότητά σας για να συνεχίσετε."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Acabas de activar el bloqueo de la app. Autentícate para continuar."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Otit juuri sovelluslukon käyttöön. Tunnistaudu jatkaaksesi."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous venez d'activer le verrouillage de l'app. Authentifiez-vous pour continuer."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "הרגע הפעלת את נעילת האפליקציה. אמתי כדי להמשיך."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपने अभी ऐप लॉक सक्षम किया है। जारी रखने के लिए प्रमाणित करें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Most kapcsoltad be az alkalmazászárat. A folytatáshoz hitelesíts."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Anda baru saja mengaktifkan Kunci Aplikasi. Autentikasi untuk melanjutkan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Hai appena attivato il blocco app. Autenticati per continuare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アプリロックを有効にしました。続けるには認証してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "방금 앱 잠금을 켰습니다. 계속하려면 인증하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Anda baru sahaja mendayakan Kunci Apl. Sahkan untuk meneruskan."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Du har nettopp aktivert applås. Autentiser deg for å fortsette."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je hebt zojuist App-vergrendeling ingeschakeld. Verifieer om door te gaan."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Właśnie włączono blokadę aplikacji. Uwierzytelnij się, aby kontynuować."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você acabou de ativar o Bloqueio do app. Autentique-se para continuar."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Acabou de ativar o Bloqueio da aplicação. Autentique-se para continuar."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Tocmai ai activat blocarea aplicației. Autentifică-te pentru a continua."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Вы только что включили блокировку приложения. Пройдите аутентификацию, чтобы продолжить."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Du har just aktiverat applås. Autentisera dig för att fortsätta."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "คุณเพิ่งเปิดการล็อกแอป ยืนยันตัวตนเพื่อดำเนินการต่อ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Uygulama Kilidini yeni etkinleştirdiniz. Devam etmek için kimliğinizi doğrulayın."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ви щойно ввімкнули блокування застосунку. Пройдіть автентифікацію, щоб продовжити."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn vừa bật khóa ứng dụng. Xác thực để tiếp tục."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你刚刚开启了应用锁。请验证身份以继续。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你剛剛開啟了 App 鎖定。請驗證身分以繼續。"
          }
        }
      }
    },
