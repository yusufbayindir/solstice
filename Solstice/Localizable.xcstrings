        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Dibuat dengan cermat. Tanpa pelacakan, tanpa cloud."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Realizzata con cura. Nessun tracciamento, nessun cloud."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "心を込めて作りました。追跡なし、クラウドなし。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "정성껏 만들었습니다. 추적도, 클라우드도 없습니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Dibina dengan teliti. Tiada penjejakan, tiada awan."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Laget med omtanke. Ingen sporing, ingen sky."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Met zorg gemaakt. Geen tracking, geen cloud."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Stworzone z troską. Bez śledzenia, bez chmury."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Feito com carinho. Sem rastreamento, sem nuvem."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Feito com cuidado. Sem rastreamento, sem nuvem."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Creată cu grijă. Fără urmărire, fără cloud."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сделано с заботой. Без отслеживания и облака."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Skapad med omsorg. Ingen spårning, inget moln."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "สร้างด้วยความใส่ใจ ไม่มีการติดตาม ไม่มีคลาวด์"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Özenle hazırlandı. Takip yok, bulut yok."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Зроблено з турботою. Жодного стеження, жодної хмари."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Được tạo nên bằng sự tận tâm. Không theo dõi, không đám mây."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "用心打造。不追踪，不上云。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "用心打造。不追蹤，不上雲。"
          }
        }
      }
    },
