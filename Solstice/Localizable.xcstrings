    "Insights computed on this iPhone — your data never leaves.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Insights computed on this iPhone — your data never leaves."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "تُحسب الإحصاءات على جهاز iPhone هذا، ولا تغادر بياناتك أبدًا."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Přehledy se počítají v tomto iPhonu — vaše data jej nikdy neopustí."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Indsigt beregnes på denne iPhone — dine data forlader den aldrig."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Einblicke werden auf diesem iPhone berechnet — deine Daten verlassen es nie."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Τα στατιστικά υπολογίζονται σε αυτό το iPhone — τα δεδομένα σας δεν φεύγουν ποτέ."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "El análisis se calcula en este iPhone — tus datos nunca salen."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Havainnot lasketaan tällä iPhonella — tietosi eivät poistu laitteelta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Analyses calculées sur cet iPhone — vos données ne sortent jamais."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "התובנות מחושבות על ה-iPhone הזה — הנתונים שלך לעולם לא יוצאים."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अंतर्दृष्टि इसी iPhone पर गणना की जाती है — आपका डेटा कभी बाहर नहीं जाता।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az elemzéseket ezen az iPhone-on számoljuk ki — az adataid sosem hagyják el."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Wawasan dihitung di iPhone ini — data Anda tidak pernah keluar."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Le analisi vengono calcolate su questo iPhone — i tuoi dati non escono mai."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "傾向はこのiPhone上で計算されます。あなたのデータが外に出ることはありません。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "인사이트는 이 iPhone에서 계산되며, 데이터는 절대 외부로 나가지 않습니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pandangan dikira pada iPhone ini — data anda tidak pernah keluar."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Innsikt beregnes på denne iPhone — dataene dine forlater den aldri."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Inzichten berekend op deze iPhone — je gegevens verlaten het apparaat nooit."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Analizy obliczane na tym iPhonie — Twoje dane nigdy go nie opuszczają."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Análises calculadas neste iPhone — seus dados nunca saem daqui."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Análises calculadas neste iPhone — os seus dados nunca saem daqui."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Statistici calculate pe acest iPhone — datele tale nu pleacă niciodată."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Аналитика рассчитывается на этом iPhone — ваши данные никуда не уходят."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Insikter beräknas på den här iPhone — dina data lämnar den aldrig."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ข้อมูลเชิงลึกคำนวณบน iPhone เครื่องนี้ — ข้อมูลของคุณไม่ออกไปไหน"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Analizler bu iPhone'da hesaplanır — verileriniz asla dışarı çıkmaz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Аналітика обчислюється на цьому iPhone — ваші дані нікуди не передаються."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Phân tích được tính toán trên iPhone này — dữ liệu của bạn không bao giờ rời đi."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "洞察均在这部 iPhone 上计算，你的数据绝不外传。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "洞察皆在這支 iPhone 上運算，你的資料絕不外傳。"
          }
        }
      }
    },
