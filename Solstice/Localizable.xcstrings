    "Your cycle is ready to track. Everything stays on this iPhone.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your cycle is ready to track. Everything stays on this iPhone."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "أصبحت دورتك جاهزة للتتبّع. كل شيء يبقى على جهاز iPhone هذا."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Váš cyklus je připraven ke sledování. Vše zůstává v tomto iPhonu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Din cyklus er klar til at blive registreret. Alt bliver på denne iPhone."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Zyklus kann jetzt erfasst werden. Alles bleibt auf diesem iPhone."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ο κύκλος σας είναι έτοιμος για παρακολούθηση. Όλα παραμένουν σε αυτό το iPhone."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu ciclo está listo para registrarse. Todo permanece en este iPhone."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kiertosi on valmiina seurattavaksi. Kaikki pysyy tällä iPhonella."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre cycle est prêt à être suivi. Tout reste sur cet iPhone."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "המחזור שלך מוכן למעקב. הכול נשאר על ה-iPhone הזה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपका चक्र ट्रैक करने के लिए तैयार है। सब कुछ इसी iPhone पर रहता है।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A ciklusod készen áll a követésre. Minden ezen az iPhone-on marad."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Siklus Anda siap dilacak. Semuanya tetap berada di iPhone ini."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo ciclo è pronto per essere monitorato. Tutto resta su questo iPhone."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "周期の記録を始める準備ができました。すべてはこのiPhoneの中にとどまります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이제 주기 기록을 시작할 수 있습니다. 모든 것은 이 iPhone 안에 머무릅니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Kitaran anda sedia untuk dijejak. Semuanya kekal pada iPhone ini."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Syklusen din er klar til å spores. Alt blir værende på denne iPhone."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je cyclus is klaar om bij te houden. Alles blijft op deze iPhone."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Możesz już śledzić swój cykl. Wszystko pozostaje na tym iPhonie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Seu ciclo está pronto para ser acompanhado. Tudo fica neste iPhone."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O seu ciclo está pronto a ser acompanhado. Tudo fica neste iPhone."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Ciclul tău e gata de urmărit. Totul rămâne pe acest iPhone."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Можно начинать отслеживать цикл. Всё остаётся на этом iPhone."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Din cykel är redo att spåras. Allt stannar på den här iPhone."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "รอบเดือนของคุณพร้อมให้ติดตามแล้ว ทุกอย่างอยู่บน iPhone เครื่องนี้"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Döngünüzü takip etmeye hazırsınız. Her şey bu iPhone'da kalır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваш цикл готовий до відстеження. Усе залишається на цьому iPhone."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chu kỳ của bạn đã sẵn sàng để theo dõi. Mọi thứ đều nằm trên iPhone này."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的周期已准备好开始记录。所有数据都留在这部 iPhone 上。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的週期已準備好開始記錄。所有資料都留在這支 iPhone 上。"
          }
        }
      }
    },
