    "From the first day of one period to the first day of the next. Most are 21–35 days.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "From the first day of one period to the first day of the next. Most are 21–35 days."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "من أول يوم في دورة إلى أول يوم في الدورة التالية. معظمها بين 21 و35 يومًا."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Od prvního dne jedné menstruace do prvního dne další. Většinou 21–35 dní."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Fra den første dag i én menstruation til den første dag i den næste. De fleste er 21–35 dage."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Vom ersten Tag einer Periode bis zum ersten Tag der nächsten. Die meisten dauern 21–35 Tage."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Από την πρώτη ημέρα μιας περιόδου έως την πρώτη ημέρα της επόμενης. Οι περισσότεροι είναι 21–35 ημέρες."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desde el primer día de un periodo hasta el primer día del siguiente. La mayoría duran 21–35 días."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kuukautisten ensimmäisestä päivästä seuraavien ensimmäiseen päivään. Useimmiten 21–35 päivää."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Du premier jour de vos règles au premier jour des suivantes. La plupart durent 21–35 jours."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "מהיום הראשון של מחזור אחד ועד היום הראשון של הבא. רוב המחזורים נמשכים 21–35 ימים."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "एक पीरियड के पहले दिन से अगले पीरियड के पहले दिन तक। अधिकांश 21–35 दिन के होते हैं।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Az egyik menstruáció első napjától a következő első napjáig. A legtöbb 21–35 nap."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Dari hari pertama satu haid sampai hari pertama haid berikutnya. Umumnya 21–35 hari."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Dal primo giorno di un ciclo al primo giorno del successivo. La maggior parte dura 21–35 giorni."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ある生理の初日から次の生理の初日までです。多くは 21〜35 日です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "한 생리의 첫날부터 다음 생리의 첫날까지입니다. 대부분 21~35일입니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Dari hari pertama satu haid hingga hari pertama haid seterusnya. Kebanyakannya 21–35 hari."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Fra første dag i én mens til første dag i den neste. De fleste er 21–35 dager."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Van de eerste dag van de ene menstruatie tot de eerste dag van de volgende. Meestal 21–35 dagen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Od pierwszego dnia jednej miesiączki do pierwszego dnia następnej. Najczęściej 21–35 dni."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Do primeiro dia de uma menstruação ao primeiro dia da seguinte. A maioria fica entre 21–35 dias."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Do primeiro dia de uma menstruação ao primeiro dia da seguinte. A maioria situa-se entre 21–35 dias."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "De la prima zi a unei menstruații până la prima zi a următoarei. Cel mai des sunt 21–35 de zile."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "От первого дня одних месячных до первого дня следующих. Чаще всего — 21–35 дней."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Från första dagen i en mens till första dagen i nästa. De flesta är 21–35 dagar."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "นับจากวันแรกของประจำเดือนรอบหนึ่งถึงวันแรกของรอบถัดไป ส่วนใหญ่อยู่ที่ 21–35 วัน"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir adetin ilk gününden bir sonrakinin ilk gününe kadar. Çoğu döngü 21–35 gündür."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Від першого дня однієї менструації до першого дня наступної. Найчастіше це 21–35 днів."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Từ ngày đầu của kỳ kinh này đến ngày đầu của kỳ kinh tiếp theo. Hầu hết là 21–35 ngày."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从一次经期的第一天算到下一次经期的第一天。大多为 21–35 天。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "從一次經期的第一天算到下一次經期的第一天。大多為 21–35 天。"
          }
        }
      }
    },
