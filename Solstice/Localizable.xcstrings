    "Unlock your full cycle picture — fertile window, deeper insights, and data you own.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unlock your full cycle picture — fertile window, deeper insights, and data you own."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "افتحي الصورة الكاملة لدورتك — نافذة الخصوبة، ورؤى أعمق، وبيانات تملكينها وحدك."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Odemkněte si úplný obraz svého cyklu — plodné období, hlubší přehledy a data, která vlastníte."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Lås op for det fulde billede af din cyklus — frugtbart vindue, dybere indsigt og data, du selv ejer."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erlebe deinen Zyklus im Ganzen — fruchtbare Tage, tiefere Einblicke und Daten, die dir gehören."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ξεκλειδώστε την πλήρη εικόνα του κύκλου σας — γόνιμο παράθυρο, βαθύτερες πληροφορίες και δεδομένα που σας ανήκουν."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Descubre tu ciclo al completo — ventana fértil, análisis más profundos y datos que te pertenecen."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Avaa koko kuva kierrostasi — hedelmällinen jakso, syvempi näkemys ja tiedot, jotka omistat itse."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Découvrez votre cycle dans son ensemble — fenêtre de fertilité, analyses approfondies et données qui vous appartiennent."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "קבלו את התמונה המלאה של המחזור שלכן — חלון הפוריות, תובנות מעמיקות יותר ונתונים שבבעלותכן."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "अपने चक्र की पूरी तस्वीर अनलॉक करें — उपजाऊ अवधि, गहरी जानकारी और वह डेटा जो आपका अपना है।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Tárd fel ciklusod teljes képét — termékeny időszak, mélyebb elemzések és adatok, amelyek a tieid."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Buka gambaran lengkap siklus Anda — masa subur, wawasan lebih mendalam, dan data milik Anda sendiri."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scopri il quadro completo del tuo ciclo — finestra fertile, analisi più approfondite e dati che ti appartengono."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サイクルの全体像をすべて解放——妊娠可能期間、より深い分析、そしてあなたが所有するデータ。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "주기의 모든 그림을 열어 보세요 — 가임기, 더 깊은 인사이트, 그리고 온전히 내 것인 데이터."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Buka gambaran penuh kitaran haid anda — tempoh subur, pandangan lebih mendalam, dan data milik anda sendiri."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Lås opp hele bildet av syklusen din — fruktbart vindu, dypere innsikt og data du eier."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ontgrendel het volledige beeld van je cyclus — vruchtbare periode, diepere inzichten en gegevens die van jou zijn."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odblokuj pełny obraz swojego cyklu — okno płodności, głębsze analizy i dane, które należą do Ciebie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desbloqueie a visão completa do seu ciclo — janela fértil, insights mais profundos e dados que são seus."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Desbloqueie a visão completa do seu ciclo — janela fértil, análises mais aprofundadas e dados que lhe pertencem."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Deblochează imaginea completă a ciclului tău — fereastra fertilă, analize mai detaliate și date care îți aparțin."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Откройте полную картину своего цикла — фертильное окно, глубокую аналитику и данные, которые принадлежат вам."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lås upp hela bilden av din cykel — fertilt fönster, djupare insikter och data som du äger."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ปลดล็อกภาพรวมรอบเดือนของคุณแบบเต็มรูปแบบ — ช่วงเจริญพันธุ์ ข้อมูลเชิงลึกที่ลึกซึ้งยิ่งขึ้น และข้อมูลที่เป็นของคุณเอง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Döngünün tüm resmini keşfet — doğurgan dönem, daha derin içgörüler ve sana ait veriler."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Відкрийте повну картину свого циклу — фертильне вікно, глибші висновки та дані, якими володієте ви."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mở khóa bức tranh đầy đủ về chu kỳ của bạn — thời kỳ dễ thụ thai, thông tin chuyên sâu hơn và dữ liệu thuộc về bạn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "解锁完整的周期全貌——易孕窗口、更深入的洞察，以及完全归你所有的数据。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "解鎖完整的週期全貌——易孕窗口、更深入的洞察，以及完全屬於你的資料。"
          }
        }
      }
    },
    "No account. No cloud. Pay once if you want.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No account. No cloud. Pay once if you want."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "بلا حساب. بلا سحابة. ادفعي مرّة واحدة إن رغبتِ."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Žádný účet. Žádný cloud. Zaplaťte jednou, pokud chcete."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen konto. Ingen sky. Betal én gang, hvis du vil."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kein Konto. Keine Cloud. Auf Wunsch nur einmal zahlen."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Χωρίς λογαριασμό. Χωρίς cloud. Πληρώστε μία φορά αν θέλετε."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Sin cuenta. Sin nube. Paga una sola vez, si quieres."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ei tiliä. Ei pilveä. Maksa kerran, jos haluat."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Sans compte. Sans cloud. Payez une seule fois, si vous le souhaitez."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "בלי חשבון. בלי ענן. שלמו פעם אחת אם תרצו."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कोई खाता नहीं। कोई क्लाउड नहीं। चाहें तो एक बार भुगतान करें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Nincs fiók. Nincs felhő. Fizess egyszer, ha szeretnél."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Tanpa akun. Tanpa cloud. Bayar sekali jika Anda mau."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Nessun account. Nessun cloud. Paga una sola volta, se vuoi."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アカウント不要。クラウド不要。お望みなら一度の支払いだけ。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "계정도, 클라우드도 필요 없어요. 원하시면 한 번만 결제하세요."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tiada akaun. Tiada awan. Bayar sekali sahaja jika anda mahu."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen konto. Ingen sky. Betal én gang om du vil."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Geen account. Geen cloud. Betaal eenmalig als je dat wilt."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Bez konta. Bez chmury. Zapłać raz, jeśli chcesz."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Sem conta. Sem nuvem. Pague uma vez, se quiser."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Sem conta. Sem nuvem. Pague uma vez, se quiser."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Fără cont. Fără cloud. Plătești o singură dată, dacă vrei."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Без аккаунта. Без облака. Заплатите один раз, если хотите."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Inget konto. Inget moln. Betala en gång om du vill."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ไม่ต้องมีบัญชี ไม่ต้องใช้คลาวด์ จ่ายครั้งเดียวหากต้องการ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Hesap yok. Bulut yok. İstersen tek seferlik öde."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Без облікового запису. Без хмари. Одна оплата, якщо забажаєте."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Không tài khoản. Không đám mây. Trả một lần nếu bạn muốn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无需账户，无需云端。愿意的话，一次付费即可。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無需帳戶，無需雲端。願意的話，一次付費即可。"
          }
        }
      }
    },
