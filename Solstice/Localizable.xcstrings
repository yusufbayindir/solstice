    "Your cycle, kept private.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your cycle, kept private."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "دورتك، تبقى خاصة بك."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Váš cyklus v soukromí."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Din cyklus, holdt privat."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Zyklus – ganz privat."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ο κύκλος σας, ιδιωτικός."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu ciclo, en privado."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kiertosi, yksityisesti."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre cycle, en toute confidentialité."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "המחזור שלך, נשמר באופן פרטי."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "आपका चक्र, निजी रखा गया।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "A ciklusod, biztonságban."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Siklus Anda, tetap pribadi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il tuo ciclo, in tutta privacy."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "あなたの周期を、あなただけのものに。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "당신의 주기, 오롯이 당신만의 것."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Kitaran anda, kekal peribadi."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Syklusen din, holdt privat."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Je cyclus, privé gehouden."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Twój cykl, w pełni prywatny."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Seu ciclo, em sigilo."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "O seu ciclo, em privado."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Ciclul tău, păstrat privat."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваш цикл под надёжной защитой."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Din cykel, helt privat."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "รอบเดือนของคุณ เป็นความลับเสมอ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Döngünüz, size özel."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Ваш цикл — під надійним захистом."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chu kỳ của bạn, được giữ riêng tư."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的周期，只属于你。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的週期，只屬於你。"
          }
        }
      }
    },
