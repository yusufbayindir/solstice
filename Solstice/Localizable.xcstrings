    "No passcode is set on this iPhone. Set a passcode in iPhone Settings to regain access.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No passcode is set on this iPhone. Set a passcode in iPhone Settings to regain access."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "لم يتم تعيين رمز دخول على جهاز iPhone هذا. عيّني رمز دخول من إعدادات iPhone لاستعادة الوصول."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "V tomto iPhonu není nastaven žádný kód. Nastavte kód v Nastavení iPhonu, abyste znovu získali přístup."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Der er ikke angivet nogen adgangskode på denne iPhone. Angiv en adgangskode under iPhone-indstillinger for at få adgang igen."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Auf diesem iPhone ist kein Code festgelegt. Lege in den iPhone-Einstellungen einen Code fest, um wieder Zugriff zu erhalten."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Δεν έχει οριστεί κωδικός σε αυτό το iPhone. Ορίστε έναν κωδικό στις Ρυθμίσεις του iPhone για να αποκτήσετε ξανά πρόσβαση."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No hay ningún código configurado en este iPhone. Configura un código en los Ajustes del iPhone para recuperar el acceso."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Tälle iPhonelle ei ole asetettu pääsykoodia. Aseta pääsykoodi iPhonen asetuksissa palauttaaksesi pääsyn."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Aucun code n'est défini sur cet iPhone. Définissez un code dans les Réglages de l'iPhone pour récupérer l'accès."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "לא הוגדר קוד גישה ב-iPhone הזה. הגדירי קוד גישה בהגדרות ה-iPhone כדי לחזור ולקבל גישה."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "इस iPhone पर कोई पासकोड सेट नहीं है। पहुँच पुनः पाने के लिए iPhone सेटिंग्स में पासकोड सेट करें।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Ezen az iPhone-on nincs beállítva jelkód. A hozzáférés visszaszerzéséhez állíts be egy jelkódot az iPhone Beállításokban."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Belum ada kode sandi yang diatur di iPhone ini. Atur kode sandi di Pengaturan iPhone untuk mendapatkan kembali akses."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Su questo iPhone non è impostato alcun codice. Imposta un codice nelle Impostazioni dell'iPhone per riottenere l'accesso."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このiPhoneにはパスコードが設定されていません。iPhoneの設定でパスコードを設定すると、再びアクセスできます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 iPhone에 암호가 설정되어 있지 않습니다. iPhone 설정에서 암호를 설정하면 다시 접근할 수 있습니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Tiada kod laluan ditetapkan pada iPhone ini. Tetapkan kod laluan dalam Tetapan iPhone untuk mendapatkan semula akses."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Det er ikke angitt noen kode på denne iPhone. Angi en kode i Innstillinger på iPhone for å få tilgang igjen."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Er is geen toegangscode ingesteld op deze iPhone. Stel een toegangscode in via Instellingen op je iPhone om weer toegang te krijgen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Na tym iPhonie nie ustawiono kodu. Ustaw kod w Ustawieniach iPhone'a, aby odzyskać dostęp."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não há código definido neste iPhone. Defina um código nos Ajustes do iPhone para recuperar o acesso."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Não está definido qualquer código neste iPhone. Defina um código nas Definições do iPhone para recuperar o acesso."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Pe acest iPhone nu este setat niciun cod de acces. Setează un cod în Setările iPhone pentru a-ți recăpăta accesul."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "На этом iPhone не задан код-пароль. Задайте его в настройках iPhone, чтобы восстановить доступ."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Ingen lösenkod är inställd på den här iPhone. Ställ in en lösenkod i iPhones Inställningar för att få tillbaka åtkomsten."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ยังไม่ได้ตั้งรหัสบน iPhone เครื่องนี้ ตั้งรหัสในการตั้งค่า iPhone เพื่อเข้าถึงอีกครั้ง"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu iPhone'da parola ayarlanmamış. Erişimi yeniden sağlamak için iPhone Ayarları'nda bir parola belirleyin."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "На цьому iPhone не встановлено код-пароль. Установіть його в Налаштуваннях iPhone, щоб відновити доступ."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chưa đặt mật mã trên iPhone này. Hãy đặt mật mã trong Cài đặt iPhone để lấy lại quyền truy cập."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "这部 iPhone 尚未设置密码。请在 iPhone 设置中设置密码以重新访问。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "這支 iPhone 尚未設定密碼。請在 iPhone 設定中設定密碼以重新存取。"
          }
        }
      }
    },
