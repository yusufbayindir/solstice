    "Pick the first day of bleeding. An estimate is fine — you can change it later.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pick the first day of bleeding. An estimate is fine — you can change it later."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "اختاري أول يوم من النزيف. يكفي تقدير تقريبي، ويمكنك تغييره لاحقًا."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Vyberte první den krvácení. Odhad stačí — později jej můžete změnit."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Vælg den første blødningsdag. Et skøn er fint — du kan ændre det senere."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle den ersten Tag der Blutung. Eine Schätzung genügt — du kannst sie später ändern."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Επιλέξτε την πρώτη ημέρα αιμορραγίας. Μια εκτίμηση αρκεί — μπορείτε να την αλλάξετε αργότερα."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige el primer día de sangrado. Una estimación es suficiente — puedes cambiarla después."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Valitse vuodon ensimmäinen päivä. Arvio riittää — voit muuttaa sitä myöhemmin."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez le premier jour des saignements. Une estimation suffit — vous pourrez la modifier plus tard."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "בחרי את היום הראשון של הדימום. הערכה מספיקה — אפשר לשנות מאוחר יותר."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "रक्तस्राव का पहला दिन चुनें। अनुमान भी ठीक है — आप इसे बाद में बदल सकते हैं।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Válaszd ki a vérzés első napját. A becslés is megfelel — később módosíthatod."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih hari pertama keluarnya darah. Perkiraan pun tidak masalah — Anda bisa mengubahnya nanti."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli il primo giorno di flusso. Va bene anche una stima — potrai modificarla in seguito."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "出血が始まった日を選んでください。おおよそで構いません。あとで変更できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "출혈이 시작된 첫날을 선택하세요. 대략적인 날짜여도 괜찮으며, 나중에 변경할 수 있습니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Pilih hari pertama pendarahan. Anggaran pun memadai — anda boleh mengubahnya kemudian."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Velg den første blødningsdagen. Et anslag holder — du kan endre det senere."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Kies de eerste dag van het bloeden. Een schatting is prima — je kunt het later aanpassen."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wybierz pierwszy dzień krwawienia. Przybliżona data wystarczy — możesz ją później zmienić."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha o primeiro dia de sangramento. Uma estimativa basta — você pode mudar depois."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha o primeiro dia de hemorragia. Uma estimativa chega — pode alterá-la mais tarde."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Alege prima zi de sângerare. O estimare e suficientă — o poți modifica mai târziu."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите первый день кровотечения. Достаточно приблизительной даты — её можно изменить позже."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Välj första blödningsdagen. En uppskattning räcker — du kan ändra den senare."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "เลือกวันแรกที่มีเลือดออก ประมาณการก็ได้ — คุณเปลี่ยนภายหลังได้"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Kanamanın ilk gününü seçin. Tahmini bir tarih de olur — daha sonra değiştirebilirsiniz."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Виберіть перший день кровотечі. Приблизна дата теж підійде — її можна змінити пізніше."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Chọn ngày đầu tiên ra máu. Ước lượng cũng được — bạn có thể thay đổi sau."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择出血的第一天。大致估计即可，之后随时可以修改。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "選擇出血的第一天。大致估計即可，之後隨時可以修改。"
          }
        }
      }
    },
