    "Unlock advanced insights — flow, symptom, and mood patterns across your cycles.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unlock advanced insights — flow, symptom, and mood patterns across your cycles."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "افتحي الرؤى المتقدّمة — أنماط التدفّق والأعراض والمزاج عبر دوراتك."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Odemkněte pokročilé přehledy — vzorce krvácení, příznaků a nálad napříč svými cykly."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Lås op for avanceret indsigt — mønstre for blødning, symptomer og humør på tværs af dine cyklusser."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Schalte erweiterte Einblicke frei — Blutungs-, Symptom- und Stimmungsmuster über deine Zyklen hinweg."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Ξεκλειδώστε προηγμένες πληροφορίες — μοτίβα ροής, συμπτωμάτων και διάθεσης σε όλους τους κύκλους σας."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Desbloquea análisis avanzados — patrones de flujo, síntomas y estado de ánimo a lo largo de tus ciclos."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Avaa edistynyt analyysi — vuodon, oireiden ja mielialan kuviot kierrostesi ajalta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Débloquez les analyses avancées — tendances du flux, des symptômes et de l'humeur au fil de vos cycles."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "פתחו תובנות מתקדמות — דפוסי זרימה, תסמינים ומצב רוח לאורך המחזורים שלכן."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "उन्नत जानकारी अनलॉक करें — अपने चक्रों में रक्तस्राव, लक्षण और मनोदशा के पैटर्न।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Oldd fel a speciális elemzéseket — a vérzés, a tünetek és a hangulat mintázatait ciklusaidon át."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Buka wawasan lanjutan — pola aliran, gejala, dan suasana hati di sepanjang siklus Anda."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sblocca le analisi avanzate — andamento di flusso, sintomi e umore lungo i tuoi cicli."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "高度な分析を解放——サイクルをまたいだ経血量・症状・気分のパターン。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "고급 인사이트 잠금 해제 — 여러 주기에 걸친 생리량, 증상, 기분 패턴."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Buka pandangan lanjutan — corak aliran, simptom, dan mood sepanjang kitaran haid anda."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Lås opp avansert innsikt — mønstre for blødning, symptomer og humør gjennom syklusene dine."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Ontgrendel geavanceerde inzichten — patronen in bloedverlies, symptomen en stemming over je cycli."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Odblokuj zaawansowane analizy — wzorce krwawienia, objawów i nastroju w kolejnych cyklach."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Desbloqueie insights avançados — padrões de fluxo, sintomas e humor ao longo dos seus ciclos."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Desbloqueie análises avançadas — padrões de fluxo, sintomas e disposição ao longo dos seus ciclos."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Deblochează analize avansate — tiparele fluxului, ale simptomelor și ale dispoziției de-a lungul ciclurilor tale."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Откройте расширенную аналитику — закономерности обильности, симптомов и настроения на протяжении ваших циклов."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Lås upp avancerade insikter — mönster för flöde, symtom och humör genom dina cykler."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "ปลดล็อกข้อมูลเชิงลึกขั้นสูง — รูปแบบของประจำเดือน อาการ และอารมณ์ตลอดรอบเดือนของคุณ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gelişmiş içgörüleri aç — döngülerin boyunca akış, semptom ve ruh hali örüntüleri."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Розблокуйте розширені висновки — закономірності виділень, симптомів і настрою впродовж ваших циклів."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Mở khóa thông tin chuyên sâu — các mẫu lượng kinh, triệu chứng và tâm trạng qua các chu kỳ của bạn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "解锁高级洞察——查看历次周期中的经量、症状与情绪规律。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "解鎖進階洞察——查看歷次週期中的經量、症狀與情緒模式。"
          }
        }
      }
    }
  },
  "version": "1.0"
}
