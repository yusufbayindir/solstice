    "Face ID is not available on this device. You can enable App Lock later in Settings.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Face ID is not available on this device. You can enable App Lock later in Settings."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "ميزة Face ID غير متوفرة على هذا الجهاز. يمكنك تفعيل قفل التطبيق لاحقًا من الإعدادات."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
