    "Log a couple of cycles and patterns will appear here — everything computed on your iPhone.": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Log a couple of cycles and patterns will appear here — everything computed on your iPhone."
          }
        },
        "ar": {
          "stringUnit": {
            "state": "translated",
            "value": "سجّلي بضع دورات وستظهر الأنماط هنا، وكل ذلك يُحسب على جهاز iPhone الخاص بك."
          }
        },
        "cs": {
          "stringUnit": {
            "state": "translated",
            "value": "Zaznamenejte několik cyklů a zde se objeví vzorce — vše vypočítané ve vašem iPhonu."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "Registrér et par cyklusser, så dukker mønstrene op her — alt beregnes på din iPhone."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Erfasse ein paar Zyklen, dann erscheinen hier Muster — alles wird auf deinem iPhone berechnet."
          }
        },
        "el": {
          "stringUnit": {
            "state": "translated",
            "value": "Καταγράψτε μερικούς κύκλους και τα μοτίβα θα εμφανιστούν εδώ — όλα υπολογίζονται στο iPhone σας."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra un par de ciclos y los patrones aparecerán aquí — todo se calcula en tu iPhone."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Kirjaa pari kiertoa, niin kaavat ilmestyvät tähän — kaikki laskettuna iPhonessasi."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Enregistrez quelques cycles et les tendances apparaîtront ici — tout est calculé sur votre iPhone."
          }
        },
        "he": {
          "stringUnit": {
            "state": "translated",
            "value": "תעדי כמה מחזורים ודפוסים יופיעו כאן — הכול מחושב על ה-iPhone שלך."
          }
        },
        "hi": {
          "stringUnit": {
            "state": "translated",
            "value": "कुछ चक्र दर्ज करें और यहाँ पैटर्न दिखाई देंगे — सब कुछ आपके iPhone पर गणना किया जाता है।"
          }
        },
        "hu": {
          "stringUnit": {
            "state": "translated",
            "value": "Rögzíts néhány ciklust, és itt megjelennek a mintázatok — mindent az iPhone-odon számolunk ki."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Catat beberapa siklus dan polanya akan muncul di sini — semuanya dihitung di iPhone Anda."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Registra un paio di cicli e qui appariranno gli andamenti — tutto viene calcolato sul tuo iPhone."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "数回分の周期を記録すると、ここにパターンが現れます。すべての計算はこのiPhone上で行われます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "주기를 몇 번 기록하면 여기에 패턴이 나타납니다. 모든 계산은 당신의 iPhone에서 이루어집니다."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Rekodkan beberapa kitaran dan corak akan muncul di sini — semuanya dikira pada iPhone anda."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "Logg et par sykluser, så dukker mønstrene opp her — alt beregnes på din iPhone."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Log een paar cycli en de patronen verschijnen hier — alles wordt op je iPhone berekend."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Zapisz kilka cykli, a tutaj pojawią się wzorce — wszystko obliczane na Twoim iPhonie."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Registre alguns ciclos e os padrões aparecerão aqui — tudo calculado no seu iPhone."
          }
        },
        "pt-PT": {
          "stringUnit": {
            "state": "translated",
            "value": "Registe alguns ciclos e os padrões aparecerão aqui — tudo calculado no seu iPhone."
          }
        },
        "ro": {
          "stringUnit": {
            "state": "translated",
            "value": "Notează câteva cicluri și tiparele vor apărea aici — totul calculat pe iPhone-ul tău."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отметьте несколько циклов, и здесь появятся закономерности — все расчёты выполняются на вашем iPhone."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Logga ett par cykler så dyker mönstren upp här — allt beräknas på din iPhone."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "บันทึกสักสองสามรอบ แล้วรูปแบบจะปรากฏที่นี่ — ทุกอย่างคำนวณบน iPhone ของคุณ"
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Birkaç döngü kaydedin; örüntüler burada görünecek — her şey iPhone'unuzda hesaplanır."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Запишіть кілька циклів, і тут з'являться закономірності — усі обчислення виконуються на вашому iPhone."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ghi nhận vài chu kỳ và các mẫu hình sẽ xuất hiện ở đây — mọi thứ đều được tính toán trên iPhone của bạn."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "记录几个周期后，规律就会在这里显现，所有计算都在你的 iPhone 上完成。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "記錄幾個週期後，規律就會在這裡顯現，所有運算都在你的 iPhone 上完成。"
          }
        }
      }
    },
