          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Прогноз стає точнішим, коли ви додаєте більше записів."
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Ước lượng sẽ chính xác hơn khi bạn ghi nhận thêm."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "记录越多，预估越准。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "記錄越多，預估越準。"
          }
        }
      }
    },
